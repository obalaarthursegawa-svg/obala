# GEMINI_API_KEY: Required for Gemini AI API calls.
# Arthur Code System automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Arthur Code System automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Secret Gallery Configurations (Default password is "123465" if not defined)
VAULT_PASSWORD="123465"

# Supabase Credentials (Optional: Runs in Sandbox Local Mode if not provided)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
